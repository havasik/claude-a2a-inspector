{
  "name": "a2a-inspector-frontend",
  "version": "2.0.0",
  "description": "A2A Inspector frontend — React 19 SPA with AI Elements and ARK support",
  "type": "module",
  "scripts": {
    "build": "npm run build:css && npm run build:js",
    "build:js": "esbuild src/app.tsx --bundle --outfile=public/script.js --platform=browser --jsx=automatic --loader:.css=css --define:process.env.NODE_ENV=\\\"production\\\"",
    "build:css": "npx @tailwindcss/cli -i src/styles/globals.css -o public/styles.css --minify",
    "watch": "concurrently \"npm run watch:js\" \"npm run watch:css\"",
    "watch:js": "esbuild src/app.tsx --bundle --outfile=public/script.js --platform=browser --jsx=automatic --loader:.css=css --watch",
    "watch:css": "npx @tailwindcss/cli -i src/styles/globals.css -o public/styles.css --watch",
    "lint": "gts lint",
    "clean": "gts clean",
    "compile": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@radix-ui/react-collapsible": "^1.1.12",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-hover-card": "^1.1.15",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@radix-ui/react-use-controllable-state": "^1.2.2",
    "@streamdown/cjk": "^1.0.2",
    "@streamdown/code": "^1.1.0",
    "@streamdown/math": "^1.0.2",
    "@streamdown/mermaid": "^1.0.2",
    "ai": "^6.0.116",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "lucide-react": "^0.577.0",
    "motion": "^12.35.0",
    "nanoid": "^5.1.6",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "shiki": "^4.0.1",
    "socket.io-client": "^4.8.1",
    "streamdown": "^2.4.0",
    "tailwind-merge": "^2.6.0",
    "use-stick-to-bottom": "^1.1.3"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.0.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.0.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^24.3.1",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "concurrently": "^9.0.0",
    "esbuild": "^0.25.9",
    "gts": "^6.0.2",
    "jsdom": "^27.2.0",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.9.2",
    "vite": "^7.3.1",
    "vitest": "^4.0.10"
  }
}
